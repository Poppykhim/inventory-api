{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["es2020", "dom"],
    "types": ["cypress", "node"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["../src/*"]
    },
    "allowSyntheticDefaultImports": true,
    "strict": true
  },
  "include": ["**/*.ts"]
}
